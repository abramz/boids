{
  "name": "boids-3d",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:cpu": "vite --open boids/cpu.html",
    "dev:gpu": "vite --open boids/gpu.html",
    "build": "npm run build:src && npm run build:md",
    "build:src": "tsc && vite build",
    "build:md": "cp README.md ABOUT.md dist/",
    "gh-pages": "gh-pages -t -d dist",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.63",
    "@types/react-dom": "^18.2.20",
    "@types/three": "^0.162.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.1.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "@react-three/fiber": "^8.15.19",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.162.0"
  },
  "lint-staged": {
    "src/**/*.{js,ts,jsx,tsx}": "eslint --cache --fix"
  }
}
